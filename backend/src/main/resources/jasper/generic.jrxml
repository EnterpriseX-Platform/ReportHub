<?xml version="1.0" encoding="UTF-8"?>
<!--
  Generic Thai summary template for Report Studio.
  Compiled at runtime by ReportRenderer via JasperCompileManager.

  Parameters:
    REPORT_TITLE  - Thai report name (name)
    REPORT_CODE   - report code, shown in the sub-header
    OFFICE_NAME   - top header line (defaults to the configured office name)
    GENERATED_AT  - generation timestamp string
  Fields (from JRBeanCollectionDataSource of FactRow):
    seq:Integer, region:String, amount:Double
-->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="generic"
              pageWidth="595" pageHeight="842"
              columnWidth="515" leftMargin="40" rightMargin="40"
              topMargin="40" bottomMargin="40">

    <parameter name="OFFICE_NAME" class="java.lang.String">
        <defaultValueExpression><![CDATA[""]]></defaultValueExpression>
    </parameter>
    <parameter name="REPORT_TITLE" class="java.lang.String">
        <defaultValueExpression><![CDATA["Summary Report"]]></defaultValueExpression>
    </parameter>
    <parameter name="REPORT_CODE" class="java.lang.String">
        <defaultValueExpression><![CDATA[""]]></defaultValueExpression>
    </parameter>
    <parameter name="GENERATED_AT" class="java.lang.String">
        <defaultValueExpression><![CDATA[""]]></defaultValueExpression>
    </parameter>

    <field name="seq" class="java.lang.Integer"/>
    <field name="region" class="java.lang.String"/>
    <field name="amount" class="java.lang.Double"/>

    <variable name="TOTAL_AMOUNT" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{amount}]]></variableExpression>
    </variable>

    <title>
        <band height="92">
            <textField>
                <reportElement x="0" y="0" width="515" height="26"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{OFFICE_NAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="30" width="515" height="22"/>
                <textElement textAlignment="Center">
                    <font size="13" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{REPORT_TITLE}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="56" width="515" height="16"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[($P{REPORT_CODE} == null || $P{REPORT_CODE}.isEmpty() ? "" : "Report code " + $P{REPORT_CODE} + "   ") + "Generated " + $P{GENERATED_AT}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="22">
            <staticText>
                <reportElement x="0" y="0" width="50" height="22" mode="Opaque" backcolor="#E8EEF7"/>
                <box>
                    <pen lineWidth="0.5"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Seq]]></text>
            </staticText>
            <staticText>
                <reportElement x="50" y="0" width="320" height="22" mode="Opaque" backcolor="#E8EEF7"/>
                <box>
                    <pen lineWidth="0.5"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[ Region]]></text>
            </staticText>
            <staticText>
                <reportElement x="370" y="0" width="145" height="22" mode="Opaque" backcolor="#E8EEF7"/>
                <box>
                    <pen lineWidth="0.5"/>
                </box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Amount (THB) ]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="50" height="20"/>
                <box>
                    <pen lineWidth="0.5"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{seq}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="50" y="0" width="320" height="20"/>
                <box leftPadding="4">
                    <pen lineWidth="0.5"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{region}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="370" y="0" width="145" height="20"/>
                <box rightPadding="4">
                    <pen lineWidth="0.5"/>
                </box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- JRXML schema requires pageFooter BEFORE summary -->
    <pageFooter>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="515" height="14"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <summary>
        <band height="26">
            <staticText>
                <reportElement x="0" y="0" width="370" height="22" mode="Opaque" backcolor="#D6E0F0"/>
                <box>
                    <pen lineWidth="0.5"/>
                </box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Total  ]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="370" y="0" width="145" height="22" mode="Opaque" backcolor="#D6E0F0"/>
                <box rightPadding="4">
                    <pen lineWidth="0.5"/>
                </box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_AMOUNT}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
